<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <QuestScriptDef>
    <defName>Util_BuildVillageWorker</defName>
    <root Class="QuestNode_Sequence">
      <nodes>
        <li Class="QuestNode_Set">
          <name>keepMonumentTicks</name>
          <value>$(15*60000)</value>
        </li>
        <li Class="QuestNode_Set">
          <name>goodwillChangeIfMonumentDestroyed</name>
          <value>-10</value>
        </li>

        <!-- <li Class="QuestNode_GetMap" /> -->

        <li Class="QuestNode_Set">
          <name>mustHaveSettlementOnLayer</name>
          <value>true</value>
          <convertTo>Boolean</convertTo>
        </li>
		
        <!-- Get asker -->
		<li Class="QuestNode_GetPawn">
			<storeAs>asker</storeAs>
			<mustBeFactionLeader>true</mustBeFactionLeader>
            <allowPermanentEnemyFaction>false</allowPermanentEnemyFaction>
			<mustBeNonHostileToPlayer>true</mustBeNonHostileToPlayer>
		</li>
		<li Class="QuestNode_GetFactionOf">
			<thing>$asker</thing>
            <storeAs>askerFaction</storeAs>
		</li>

        <!-- . . . . GENERATE SITE . . . . . -->
		<li Class="QuestNode_GetSiteTile">
          <storeAs>siteTile</storeAs>
          <preferCloserTiles>false</preferCloserTiles>
        </li>
        <li Class="QuestNode_GetSitePartDefsByTagsAndFaction">
          <storeAs>sitePartDefs</storeAs>
          <storeFactionAs>fakeSiteFaction</storeFactionAs>
          <sitePartsTags>
            <li><tag>LoGiQ_PlaceToBuildAt</tag></li>
          </sitePartsTags>
        </li>
		<li Class="QuestNode_GetDefaultSitePartsParams">
          <tile>$siteTile</tile>
          <faction>$askerFaction</faction>
          <sitePartDefs>$sitePartDefs</sitePartDefs>
          <storeSitePartsParamsAs>sitePartsParams</storeSitePartsParamsAs>
        </li>
		<li Class="QuestNode_SubScript">
          <def>Util_GenerateSite</def>
        </li>
        
        <li Class="QuestNode_SpawnWorldObjects">
          <worldObjects>$site</worldObjects>
        </li>
        <!-- . . . . . . . . . . . . . . . . . . . . -->

        <!-- . . . . . . . . REWARDS . . . . . . . . -->
		<li Class="QuestNode_GetMap"/>
        <li Class="QuestNode_Set">
          <name>rewardValue</name>
          <value>$($points * randFloat(1.9, 2.2))</value>
        </li>
		<!-- Factor up reward value if a punishment is threatened -->
        <li Class="QuestNode_IsTrue"> 
          <value>$needProtect</value>
          <node Class="QuestNode_Sequence">
            <nodes>
              <li Class="QuestNode_Multiply">
                <value1>$rewardValue</value1>
                <value2>1.25</value2>
                <storeAs>rewardValue</storeAs>
              </li>
            </nodes>
          </node>
        </li>
		
		<!-- How many buildings must be build -->
		<li Class="QuestNode_Set">
			<name>buildingPrice</name>
			<value>750</value>
			<convertTo>Double</convertTo>
		</li>
		<li Class="QuestNode_Set">
			<name>buildingsCount</name>
			<value>$(round($points / $buildingPrice))</value>
			<convertTo>Int32</convertTo>
		</li>
		<!-- <li Class="QuestNode_Message"> -->
			<!-- <text>$buildingsCount</text> -->
		<!-- </li> -->
		<!-- <li Class="QuestNode_Message"> -->
			<!-- <text>$points</text> -->
		<!-- </li> -->
		<li Class="LoGiQ.QuestNodes.QuestNode_Progress">
			<inSignal>AnySketchComplete</inSignal>
			<increment>1</increment>
			<progressMin>0</progressMin>
			<progressMax>$buildingsCount</progressMax>
			<progressMessage TKey="ProgressMessage">construction progress</progressMessage>
			<outSignalComplete>ConstructionCompleted</outSignalComplete>
		</li>
		
		<li Class="QuestNode_Signal">
		    <inSignal>ConstructionCompleted</inSignal>
            <node Class="QuestNode_Sequence">
				<nodes>
				    <li Class="QuestNode_Letter">
					  <label>All contruction complete. Now you can leave.</label>
					  <letterDef>PositiveEvent</letterDef>
					  <text>You completed construction of all buildings. To finish your contract leave the rooms undamaged.</text>
				    </li>
					<li Class="QuestNode_Signal">
						<inSignal>site.Destroyed</inSignal>
						<node Class="QuestNode_Sequence">
						  <nodes>
							<li Class="QuestNode_GiveRewards">
							  <parms>
								<allowGoodwill>true</allowGoodwill>
								<allowRoyalFavor>true</allowRoyalFavor>
							  </parms>
							</li>	
							<li Class="QuestNode_End">
								<outcome>Success</outcome>
								<sendStandardLetter>true</sendStandardLetter>
							</li>
						  </nodes>
						</node>
					</li>
				</nodes>
			</node>
        </li>
		

		
		<!-- Calculate construction time limit -->
        <li Class="QuestNode_Set">
          <name>constructionTimeoutTicks</name>
          <value>$(roundToTicksRough(randInt(10, 15)*60000))</value> <!-- 10~15 days at minimum -->
        </li>
		<!-- Multiply construction time for really big monuments -->
        <li Class="QuestNode_EvaluateSimpleCurve">
          <value>$points</value>
          <storeAs>timeoutFactorForPoints</storeAs> 
          <curve>
            <points>
              <li>(1000, 1)</li>
              <li>(3000, 1.5)</li>
              <li>(6000, 2.5)</li>
            </points>
          </curve>
        </li>
        <li Class="QuestNode_Multiply">
          <value1>$constructionTimeoutTicks</value1>
          <value2>$timeoutFactorForPoints</value2>
          <storeAs>constructionTimeoutTicks</storeAs>
        </li>
		
	    <!-- End condition for failure: Construction time limit expired -->
        <li Class="QuestNode_Delay">
          <delayTicks>$constructionTimeoutTicks</delayTicks>
          <inSignalDisable>ConstructionCompleted</inSignalDisable>
          <isQuestTimeout>true</isQuestTimeout>
          <node Class="QuestNode_Sequence">
            <nodes>
              <!-- Minor problem: This can send at the same moment as the quest completion letter. -->
              <li Class="QuestNode_Letter">
                <label TKey="LetterLabelTimeExpired">Monument time expired</label>
                <text TKey="LetterTextTimeExpired">Your time limit to construct the monument has expired.</text>
              </li>
              <li Class="QuestNode_End">
                <outcome>Fail</outcome>
				<sendStandardLetter>true</sendStandardLetter>
                <goodwillChangeAmount>-5</goodwillChangeAmount>
                <goodwillChangeFactionOf>$asker</goodwillChangeFactionOf>
                <goodwillChangeReason>MonumentConstructionExpired</goodwillChangeReason>
              </li>
            </nodes>
          </node>
        </li>

		<!-- todo build marker for ranch -->

		<li Class="QuestNode_LoopCount">
		  <loopCount>$buildingsCount</loopCount>
		  <storeLoopCounterAs>cnt</storeLoopCounterAs>
		  <node Class="QuestNode_Sequence">
		    <nodes>
				<li Class="QuestNode_RandomNode">
				  <nodes>
                    <li Class="QuestNode_SubScript">
						<def>Util_BuildVillageWorker_BedroomThings</def>
						<!-- <returnVarNames> -->
							<!-- <li>CornerThing</li><li>CenterThing</li><li>EdgeThing</li> -->
						<!-- </returnVarNames> -->
						<selectionWeight>0.35</selectionWeight>
					</li>
					<li Class="QuestNode_SubScript">
						<def>Util_BuildVillageWorker_DiningRoomThings</def>
						<selectionWeight>0.15</selectionWeight>
					</li>
					<li Class="QuestNode_SubScript">
						<def>Util_BuildVillageWorker_Production</def>
						<selectionWeight>0.20</selectionWeight>
					</li>
					<li Class="QuestNode_SubScript">
						<def>Util_BuildVillageWorker_RecRoom</def>
						<selectionWeight>0.15</selectionWeight>
					</li>
					<li Class="QuestNode_SubScript">
						<def>Util_BuildVillageWorker_Brewery</def>
						<selectionWeight>0.05</selectionWeight>
					</li>
					<li Class="QuestNode_SubScript">
						<def>Util_BuildVillageWorker_Laboratory</def>
						<selectionWeight>0.05</selectionWeight>
					</li>
					<li Class="QuestNode_SubScript">
						<def>Util_BuildVillageWorker_Power</def>
						<selectionWeight>0.05</selectionWeight>
					</li>
				  </nodes>
				</li>

				<li Class="LoGiQ.QuestNodes.QuestNode_GenerateSketch">
				  <storeAs>roomSketch</storeAs>
				  <sketchResolverDefName>Room</sketchResolverDefName>
				  <cornerThing>$CornerThing</cornerThing>
				  <centerThing>$CenterThing</centerThing>
				  <edgeThing>$EdgeThing</edgeThing>
				  <pointsPerArea>7.5</pointsPerArea>
				  <points>$buildingPrice</points>
				  <maxSize>40</maxSize>
				</li>

				<!-- Make monument marker -->
				<li Class="LoGiQ.QuestNodes.QuestNode_GenerateRoomMarker">
				  <storeAs>roomMarker</storeAs>
				  <sketch>$roomSketch</sketch>
				</li>
				<li Class="QuestNode_Set">
					<name>roomMarker$cnt</name>
					<value>$roomMarker</value>
				</li>
				<li Class="QuestNode_DestroyOrPassToWorldOnCleanup">
				  <things>$roomMarker</things>
				</li>	
				<li Class="QuestNode_AddToList">
				  <name>allMarkers</name>
				  <value>$roomMarker</value>
				</li>

				<!-- End if map removed -->
				<li Class="QuestNode_End">
				  <inSignal>roomMarker$cnt.LeftBehind</inSignal>
				  <outcome>Fail</outcome>
				  <sendStandardLetter>true</sendStandardLetter>
				  <goodwillChangeAmount>-15</goodwillChangeAmount>
				  <goodwillChangeFactionOf>$asker</goodwillChangeFactionOf>
				  <goodwillChangeReason>MonumentConstructionMapRemoved</goodwillChangeReason>
				</li>

				<!-- BAD. Its triggers when marker placed on ground -->
 				<!-- <li Class="QuestNode_Signal"> -->
				  <!-- <inSignal>roomMarker$cnt.Destroyed</inSignal> -->
				  <!-- <node Class="QuestNode_End"> -->
					<!-- <outcome>Fail</outcome> -->
					<!-- <sendStandardLetter>true</sendStandardLetter> -->
					<!-- <goodwillChangeAmount>-15</goodwillChangeAmount> -->
					<!-- <goodwillChangeFactionOf>$asker</goodwillChangeFactionOf> -->
					<!-- <goodwillChangeReason>MonumentConstructionMapRemoved</goodwillChangeReason> -->
				  <!-- </node> -->
				<!-- </li>  -->
				
				<li Class="QuestNode_Signal">
				  <inSignal>roomMarker$cnt.MonumentCompleted</inSignal>
				  <outSignals><li>AnySketchComplete</li></outSignals>
				</li>
				<!-- Drop monument marker -->
				<li Class="QuestNode_MakeMinified">
				  <storeAs>roomMarkerMinified</storeAs>
				  <thing>$roomMarker</thing>
				</li>
				<li Class="QuestNode_AddToList">
				  <name>thingsToDrop</name>
				  <value>$roomMarkerMinified</value>
				</li>
				<li Class="QuestNode_GenerateNonBuildableMonumentRequiredResources">
				  <addToList>thingsToDrop</addToList>
				  <monumentMarker>$roomMarker</monumentMarker>
				</li>
			</nodes>
          </node>
		</li>
		<li Class="LoGiQ.QuestNodes.QuestNode_GetSketchesRequiredResourcesString">
          <markers>$allMarkers</markers>
          <storeAs>monumentRequiredResources</storeAs>
          <storeMarketValueAs>monumentRequiredResourcesMarketValue</storeMarketValueAs>
        </li>
		<li Class="LoGiQ.QuestNodes.QuestNode_DropPodsSite">
		  <inSignal>site.MapGenerated</inSignal>
		  <siteToDrop>$site</siteToDrop>
		  <contents>$thingsToDrop</contents>
		  <useTradeDropSpot>true</useTradeDropSpot>
		  <thingsToExcludeFromHyperlinks>$thingsToDrop</thingsToExcludeFromHyperlinks>
		</li>

      </nodes>
    </root>
  </QuestScriptDef>

</Defs>