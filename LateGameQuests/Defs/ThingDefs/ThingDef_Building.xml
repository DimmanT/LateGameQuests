			<!-- <massCapacity>1000</massCapacity> -->
			<!-- <max1PerGroup>true</max1PerGroup> -->
			<!-- <canChangeAssignedThingsAfterStarting>false</canChangeAssignedThingsAfterStarting> -->
			<!-- <showOverallStats>false</showOverallStats> -->
		  <!-- </li> -->
		<!-- </comps> -->
		<minTechLevelToBuild>Animal</minTechLevelToBuild>
		<maxTechLevelToBuild>Animal</maxTechLevelToBuild>
		<designationCategory>Misc</designationCategory>
		<designatorDropdown>LoGiQ_DesignatorInteractableThings</designatorDropdown>
	</ThingDef>
	
	<ThingDef ParentName="CustomToolBase">
		<defName>LoGiQ_MiningDrain</defName>
        <label>MiningDrain</label>
        <description>Outcome for mined ore.</description>
		<thingClass>QuestEditor_Library.CustomContainer</thingClass>
		<graphicData>
		  <texPath>Things/Building/Production/Hopper</texPath>
		  <graphicClass>Graphic_Multi</graphicClass>
		  <!-- <drawSize>(2,2)</drawSize> -->
		</graphicData>
		<statBases>
			<MaxHitPoints>500</MaxHitPoints>
		</statBases>
		<size>(1,1)</size>
		<rotatable>false</rotatable>
		<tickerType>Never</tickerType>
		<passability>PassThroughOnly</passability>
		<pathCost>42</pathCost>
		<castEdgeShadows>false</castEdgeShadows>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<modExtensions>
            <li Class="QuestEditor_Library.ModExtension_CustomThing">
                <captureTrapGraphicdata_Front>
				  <texPath>Things/Building/Production/Hopper</texPath>
				  <graphicClass>Graphic_Multi</graphicClass>
                </captureTrapGraphicdata_Front>
                <captureTrapGraphicdata_Back>
				  <texPath>Things/Building/Production/Hopper</texPath>
				  <graphicClass>Graphic_Multi</graphicClass>
                </captureTrapGraphicdata_Back>
                <caturedDrawOffset>0,0.5,-0.2</caturedDrawOffset>
            </li>
        </modExtensions>
		<minTechLevelToBuild>Animal</minTechLevelToBuild>
		<maxTechLevelToBuild>Animal</maxTechLevelToBuild>
		<designationCategory>Misc</designationCategory>
		<designatorDropdown>LoGiQ_DesignatorInteractableThings</designatorDropdown>
	</ThingDef>

	<ThingDef ParentName="CustomThingBase">
        <defName>LoGiQ_Cabinet</defName>
        <label>Locked cabinet</label>
        <description>A cabinet that has been around for an unknown period of time may contain some valuable treasures.</description>
        <thingClass>QuestEditor_Library.LootBox</thingClass>
        <category>Building</category>
        <size>(2,1)</size>
        <graphicData>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(2,1)</drawSize>
            <texPath>Things/Building/LoGiQ_Cabinet/logiq_cabinet</texPath>
        </graphicData>
        <costStuffCount>50</costStuffCount>
        <useHitPoints>true</useHitPoints>
        <statBases>
            <MaxHitPoints>350</MaxHitPoints>
            <Mass>20</Mass>
        </statBases>
        <stuffCategories>
            <li>Metallic</li>
            <li>Woody</li>
        </stuffCategories>
        <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
        <building>
            <expandHomeArea>true</expandHomeArea>
            <claimable>true</claimable>
        </building>
    </ThingDef>

</Defs>